# --- OpenRouter (optional AI features -- env var named OPENAI_API_KEY but hits openrouter.ai, dormant at launch) ---
OPENAI_API_KEY=sk-...

# --- LemonSqueezy (payment checkout + webhooks) ---
# Public (exposed to the webapp at build time) — used by the /pricing page to
# construct checkout URLs of the form:
#   <NEXT_PUBLIC_LS_STORE_URL>/checkout/buy/<variant_id>?checkout[custom][user_id]=<uuid>
NEXT_PUBLIC_LS_STORE_URL=https://yourstore.lemonsqueezy.com
NEXT_PUBLIC_LS_VARIANT_STARTER=var_monthly_starter
NEXT_PUBLIC_LS_VARIANT_STARTER_ANNUAL=var_annual_starter

# Server-only — used by the FastAPI /webhook route
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_VARIANT_STARTER=var_monthly_starter
LEMONSQUEEZY_VARIANT_STARTER_ANNUAL=var_annual_starter

# --- Resend (email delivery -- dormant at launch) ---
RESEND_API_KEY=re_...

# --- API URL -- points the webapp at the FastAPI backend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Base URL -- public-facing base URL for the webapp ---
NEXT_PUBLIC_BASE_URL=http://localhost:3005

# --- CORS -- allowed origins for the FastAPI backend ---
CORS_ORIGINS=http://localhost:3005
