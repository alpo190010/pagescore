# =============================================================================
# Alpo — Production Environment Variables
# =============================================================================
# Copy to .env on the droplet and fill in real values.
# grep CHANGE_ME_ .env  →  shows any unfilled secrets
# =============================================================================

# --- Postgres (docker-compose.prod.yml db service) ---
POSTGRES_USER=alpo
POSTGRES_PASSWORD=CHANGE_ME_pg_password
POSTGRES_DB=alpo

# --- App database connection (points to Docker-internal Postgres) ---
DATABASE_URL=postgresql://alpo:CHANGE_ME_pg_password@db:5432/alpo
DB_SSL=false

# --- OpenRouter (AI analysis — env var named OPENAI_API_KEY but hits openrouter.ai) ---
OPENAI_API_KEY=CHANGE_ME_openrouter_key

# --- Resend (email delivery for paid reports) ---
RESEND_API_KEY=CHANGE_ME_resend_key

# --- LemonSqueezy (payment webhooks) ---
LEMONSQUEEZY_WEBHOOK_SECRET=CHANGE_ME_lemonsqueezy_secret
