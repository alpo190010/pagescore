:80 {
	reverse_proxy app:3000
}

alpo.ai {
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://us.i.posthog.com; style-src 'self' 'unsafe-inline'; img-src 'self' https://cdn.shopify.com https://lh3.googleusercontent.com data:; font-src 'self'; connect-src 'self' https://api.alpo.ai https://us.i.posthog.com; frame-ancestors 'none'; form-action 'self' https://accounts.google.com; base-uri 'self'; object-src 'none'"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	encode zstd gzip
	reverse_proxy app:3000
}

www.alpo.ai {
	redir https://alpo.ai{uri} permanent
}

api.alpo.ai {
	header {
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	encode zstd gzip
	reverse_proxy api:8000
}
